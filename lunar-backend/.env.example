# Lunar Solar Simulator - Environment Configuration
# Copy this file to .env and modify as needed

# API Settings
APP_NAME="Lunar Solar Simulator API"
APP_VERSION="2.0.0"
DEBUG=false

# Server Settings
HOST=0.0.0.0
PORT=8000

# CORS Settings (comma-separated list)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Simulation Limits
MAX_SIMULATION_HOURS=168
MAX_GROUND_STATIONS=50
MAX_RING_WIDTH_KM=500.0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Logging
LOG_LEVEL=INFO
